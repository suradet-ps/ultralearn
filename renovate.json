{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 6am on monday"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "description": "Group all minor/patch updates into a single PR",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all minor/patch dependencies"
    },
    {
      "description": "Pin dev dependencies to exact versions",
      "matchDepTypes": ["devDependencies"],
      "rangeStrategy": "pin"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "groupName": "security updates"
  }
}
